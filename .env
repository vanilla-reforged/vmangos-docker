MYSQL_ROOT_PASSWORD=mangos
TZ=Europe/Amsterdam
WAIT_HOSTS=vmangos-database:3306
WAIT_TIMEOUT=120
VMANGOS_CLIENT=5875

# vmangos-api key
VMANGOS_API_KEY=your_super_secret_key_here

# vmangos-api soap
MANGOS_REG_USER=yourSOAPuser
MANGOS_REG_PASS=yourSOAPpassword

# vmangos-api db connection for account checks
VMANGOS_DB_HOST=vmangos-database
VMANGOS_DB_USER=${MANGOS_DBUSER}
VMANGOS_DB_PASS=${MANGOS_DBPASS}
VMANGOS_DB_NAME=realmd
